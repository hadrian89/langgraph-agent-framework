# ── LLM Provider ─────────────────────────────────────────────────────────────
# Choose "openai" or "ollama"
LLM_PROVIDER=openai

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Ollama (required when LLM_PROVIDER=ollama)
# Start Ollama locally: https://ollama.com
OLLAMA_MODEL=llama3.2
OLLAMA_URL=http://localhost:11434

# ── Observability ─────────────────────────────────────────────────────────────
# OpenTelemetry collector endpoint (traces are sent here via gRPC)
# Leave as default for local Jaeger / Grafana Tempo, or remove to disable OTLP export
OTEL_ENDPOINT=http://localhost:4317
